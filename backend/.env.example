# Charles Schwab API (primary broker + market data)
SCHWAB_CLIENT_ID=your-schwab-client-id
SCHWAB_CLIENT_SECRET=your-schwab-client-secret
SCHWAB_REFRESH_TOKEN=your-schwab-refresh-token
SCHWAB_ACCOUNT_NUMBER=your-schwab-account-number

# Server
PORT=3010
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
